<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:BankAccountSimulator"
    x:Class="BankAccountSimulator.MainWindow"
    Width="800" Height="450"
    Title="BankAccountSimulator">

    <Grid>
        <StackPanel Name="LoginPanel" Spacing="10"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <TextBlock HorizontalAlignment="Center">Card Number</TextBlock>
            <TextBox Name="cardNumber" />
            <TextBlock HorizontalAlignment="Center">Card Pin</TextBlock>
            <TextBox Name="cardPin" />
            <TextBlock Name="resultText" />
            <Button Content="Submit" Click="HandleSignInClick"
                Name="submitButton" HorizontalAlignment="Center" />
            <local:NumberPad Name="loginPad" />
        </StackPanel>

        <StackPanel Name="DashboardPanel" IsVisible="False" HorizontalAlignment="Center">
            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" VerticalAlignment="Top"
                Margin="10">
                Welcome!</TextBlock>

            <StackPanel Margin="0, 40, 0, 0">
                <TextBlock>1. Check Balance</TextBlock>
                <TextBlock>2. Withdraw</TextBlock>
                <TextBlock>3. Deposit</TextBlock>
                <local:NumberPad Name="dashPad" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>