<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="BankAccountSimulator.MainWindow"
    Width="800" Height="450"
    Title="BankAccountSimulator">

    <StackPanel Spacing="10"
        HorizontalAlignment="Center"
        VerticalAlignment="Center">

        <TextBlock>Card Number</TextBlock>
        <TextBox Name="cardNumber" />
        <TextBlock>Card Pin</TextBlock>
        <TextBox Name="cardPin" />

        <TextBlock Name="resultText1" />
        <TextBlock Name="resultText2" />

        <Button Content="Submit" Click="HandleSignInClick"
            Name="submitButton" />

    </StackPanel>

</Window>